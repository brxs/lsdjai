{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "slipmate-midi-spike",
  "version": "0.0.0",
  "identifier": "com.slipmate.midi-spike",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SlipMate — MIDI Spike (DDJ-FLX4)",
        "width": 900,
        "height": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
